<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" styleClass="root-pane" stylesheets="@ardhi.css" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.FinanceDashboardController">
    <content>
        <BorderPane style="-fx-background-color: transparent;">
            
            <!-- Sidebar Gauche (Style Catalogue) -->
            <left>
                <VBox prefWidth="270" spacing="16" styleClass="sidebar">
                    <padding>
                        <Insets top="28" right="22" bottom="28" left="22"/>
                    </padding>
                    <Label text="Ardhi" styleClass="sidebar-title"/>
                    <Label text="Finance Console" styleClass="sidebar-section-title" wrapText="true"/>
                    
                    <VBox spacing="10" styleClass="sidebar-panel">
                        <Label text="Navigation" styleClass="sidebar-panel-title"/>
                        <Button text="Retour Accueil" onAction="#handleBackHome" styleClass="sidebar-nav-button" maxWidth="1.7976931348623157E308"/>
                    </VBox>
                    
                    <VBox spacing="10" styleClass="sidebar-panel">
                        <Label text="Operations" styleClass="sidebar-panel-title"/>
                        <Button text="Mes Transactions" onAction="#handleOpenTransactions" styleClass="sidebar-nav-button" maxWidth="1.7976931348623157E308"/>
                        <Button text="Comptes et Cartes" onAction="#handleOpenWallets" styleClass="sidebar-nav-button" maxWidth="1.7976931348623157E308"/>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS"/>
                    <VBox spacing="10" styleClass="sidebar-panel" style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 15; -fx-background-radius: 15;">
                        <Label text="Exportation" styleClass="sidebar-panel-title"/>
                        <Button text="Generer Rapport PDF" onAction="#generatePDF" styleClass="btn-primary" maxWidth="1.7976931348623157E308"/>
                    </VBox>
                </VBox>
            </left>

            <center>
                <VBox spacing="24" styleClass="content-box">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <!-- Header Section -->
                    <VBox spacing="12" styleClass="admin-header-card">
                        <Label text="Tableau de Bord Financier" styleClass="page-title" textFill="WHITE"/>
                        <Label text="Visualisez la sante financiere de votre exploitation en temps reel, suivez vos revenus et depenses." 
                               wrapText="true" styleClass="auth-subtitle" textFill="WHITE"/>
                    </VBox>

                    <!-- Stat Cards Row -->
                    <HBox spacing="20.0">
                        <children>
                            <VBox prefHeight="160.0" HBox.hgrow="ALWAYS" spacing="12.0" style="-fx-background-color: linear-gradient(to bottom right, #063D2F, #085041); -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                                <children>
                                    <Label text="SOLDE TOTAL" textFill="#5DCAA5" style="-fx-font-weight: bold; -fx-font-size: 12;"/>
                                    <Label fx:id="totalCapitalLabel" text="0.00 DT" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 30;"/>
                                    <HBox spacing="10.0">
                                        <children>
                                            <Label fx:id="eurLabel" text="0.00 €" textFill="#94A3B8" style="-fx-font-size: 13;" />
                                            <Label fx:id="usdLabel" text="0.00 $" textFill="#94A3B8" style="-fx-font-size: 13;" />
                                        </children>
                                    </HBox>
                                    <Region VBox.vgrow="ALWAYS" />
                                    <Label text="ANALYSE STABLE" textFill="#5DCAA5" style="-fx-font-weight: bold; -fx-font-size: 11;"/>
                                </children>
                            </VBox>

                            <VBox prefHeight="160.0" HBox.hgrow="ALWAYS" spacing="12.0" styleClass="card">
                                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                                <children>
                                    <Label text="REVENUS DU MOIS" textFill="#64748B" style="-fx-font-weight: bold; -fx-font-size: 12;"/>
                                    <Label fx:id="totalRevenueLabel" text="0.00 DT" textFill="#10B981" style="-fx-font-weight: bold; -fx-font-size: 28;"/>
                                    <Region VBox.vgrow="ALWAYS" />
                                    <Label text="📈 +12% vs mois dernier" textFill="#10B981" style="-fx-font-weight: bold; -fx-font-size: 11;" />
                                </children>
                            </VBox>

                            <VBox prefHeight="160.0" HBox.hgrow="ALWAYS" spacing="12.0" styleClass="card">
                                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                                <children>
                                    <Label text="DEPENSES DU MOIS" textFill="#64748B" style="-fx-font-weight: bold; -fx-font-size: 12;"/>
                                    <Label fx:id="totalExpenseLabel" text="0.00 DT" textFill="#F43F5E" style="-fx-font-weight: bold; -fx-font-size: 28;"/>
                                    <Region VBox.vgrow="ALWAYS" />
                                    <Label text="📉 -5% optimisation" textFill="#F43F5E" style="-fx-font-weight: bold; -fx-font-size: 11;" />
                                </children>
                            </VBox>
                        </children>
                    </HBox>

                    <!-- Cartes Bancaires -->
                    <VBox spacing="15" styleClass="card">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <Label text="💳 Mes Cartes Bancaires" styleClass="section-title"/>
                        <ScrollPane fitToHeight="true" minHeight="160.0" prefHeight="160.0" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                            <content>
                                <HBox fx:id="cardsContainer" spacing="15.0">
                                    <!-- Les cartes bancaires seront ajoutées dynamiquement ici -->
                                </HBox>
                            </content>
                        </ScrollPane>
                    </VBox>

                    <!-- Charts & Lists Row -->
                    <HBox spacing="24.0" VBox.vgrow="ALWAYS">
                        <children>
                            <!-- Evolution -->
                            <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS">
                                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                                <children>
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <children>
                                            <Label text="Evolution Financiere" styleClass="section-title"/>
                                            <Region HBox.hgrow="ALWAYS" />
                                            <ComboBox fx:id="chartScaleCombo" prefWidth="100.0" style="-fx-font-size: 11;"/>
                                            <Button text="📄 PDF" onAction="#generatePDF" styleClass="btn-primary" style="-fx-font-size: 11; -fx-padding: 5 12;"/>
                                        </children>
                                    </HBox>
                                    <BarChart fx:id="revenueTrendChart" animated="false" prefHeight="350.0" verticalGridLinesVisible="false">
                                        <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                                        <yAxis><NumberAxis side="LEFT" /></yAxis>
                                    </BarChart>
                                </children>
                            </VBox>

                            <!-- Side Info -->
                            <VBox prefWidth="380.0" spacing="20.0">
                                <children>
                                    <VBox spacing="12.0" styleClass="card">
                                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                                        <Label text="📊 Solde des Budgets" styleClass="section-title"/>
                                        <VBox fx:id="walletProgressVBox" spacing="8.0" />
                                    </VBox>
                                    
                                    <VBox spacing="12.0" styleClass="card" VBox.vgrow="ALWAYS">
                                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                                        <Label text="📋 Dernieres Transactions" styleClass="section-title"/>
                                        <VBox fx:id="recentTransactionsVBox" spacing="8.0" />
                                        <Separator opacity="0.3"/>
                                        <Label text="Sources de Capital" styleClass="section-title" style="-fx-font-size: 14;"/>
                                        <VBox fx:id="sourcesListVBox" spacing="8.0" />
                                    </VBox>
                                </children>
                            </VBox>
                        </children>
                    </HBox>
                </VBox>
            </center>
        </BorderPane>
    </content>
</ScrollPane>
