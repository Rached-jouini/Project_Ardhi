<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="850.0" prefWidth="1200.0" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.FinanceDashboardController">
   <children>
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <content>
            <VBox spacing="30.0" style="-fx-padding: 30;">
               <children>
            <!-- Header Section -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Tableau de Bord Financier" textFill="#063D2F">
                           <font><Font name="System Bold" size="30.0" /></font>
                        </Label>
                        <Label text="Visualisez la sante financiere de votre exploitation en temps reel" textFill="#64748B" />
                     </children>
                  </VBox>
                  <HBox spacing="15.0">
                     <children>
                        <!-- Les boutons d'action sont maintenant dans la barre latérale pour un design plus épuré -->
                     </children>
                  </HBox>
               </children>
            </HBox>

            <!-- Stat Cards Row -->
            <HBox spacing="25.0">
               <children>
                  <VBox prefHeight="180.0" prefWidth="380.0" spacing="15.0" style="-fx-background-color: linear-gradient(to bottom right, #063D2F, #085041); -fx-background-radius: 25; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(6,61,47,0.3), 20, 0, 0, 10);">
                     <children>
                        <Label text="SOLDE TOTAL" textFill="#5DCAA5"><font><Font name="System Bold" size="13.0" /></font></Label>
                        <Label fx:id="totalCapitalLabel" text="0.00 DT" textFill="WHITE"><font><Font name="System Bold" size="36.0" /></font></Label>
                        <HBox spacing="10.0">
                           <children>
                              <Label fx:id="eurLabel" text="0.00 €" textFill="#94A3B8" style="-fx-font-size: 14;" />
                              <Label fx:id="usdLabel" text="0.00 $" textFill="#94A3B8" style="-fx-font-size: 14;" />
                           </children>
                        </HBox>
                        <Region VBox.vgrow="ALWAYS" />
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Label text="Analyse du risque :" textFill="WHITE" opacity="0.7" />
                              <Label text="STABLE" textFill="#5DCAA5" style="-fx-font-weight: bold;" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <VBox prefHeight="180.0" prefWidth="380.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 25; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 8);">
                     <children>
                        <Label text="REVENUS DU MOIS" textFill="#64748B"><font><Font name="System Bold" size="13.0" /></font></Label>
                        <Label fx:id="totalRevenueLabel" text="0.00 DT" textFill="#10B981"><font><Font name="System Bold" size="34.0" /></font></Label>
                        <Region VBox.vgrow="ALWAYS" />
                        <HBox alignment="CENTER_LEFT" spacing="5.0">
                           <children>
                              <Label text="📈 +12% " textFill="#10B981" style="-fx-font-weight: bold;" />
                              <Label text="par rapport au mois dernier" textFill="#94A3B8" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <VBox prefHeight="180.0" prefWidth="380.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 25; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 8);">
                     <children>
                        <Label text="DEPENSES DU MOIS" textFill="#64748B"><font><Font name="System Bold" size="13.0" /></font></Label>
                        <Label fx:id="totalExpenseLabel" text="0.00 DT" textFill="#F43F5E"><font><Font name="System Bold" size="34.0" /></font></Label>
                        <Region VBox.vgrow="ALWAYS" />
                        <HBox alignment="CENTER_LEFT" spacing="5.0">
                           <children>
                              <Label text="📉 -5% " textFill="#F43F5E" style="-fx-font-weight: bold;" />
                              <Label text="optimisation des couts" textFill="#94A3B8" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
            <!-- Titre Section Cartes Bancaires -->
            <Label text="Mes Cartes Bancaires" textFill="#063D2F">
               <font><Font name="System Bold" size="18.0" /></font>
            </Label>

            <!-- Cartes bancaires dynamiques depuis la base de données -->
            <ScrollPane fitToHeight="true" minHeight="180.0" prefHeight="180.0" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
               <content>
                  <HBox fx:id="cardsContainer" spacing="20.0" style="-fx-padding: 0 0 10 0;">
                     <!-- Les cartes bancaires seront ajoutées dynamiquement ici -->
                  </HBox>
               </content>
            </ScrollPane>

            <!-- Charts Section -->
            <HBox spacing="25.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 25; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 8);" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15">
                           <children>
                              <Label text="Evolution Financiere" textFill="#063D2F">
                                 <font><Font name="System Bold" size="18.0" /></font>
                              </Label>
                              <Region HBox.hgrow="ALWAYS" />
                              <ComboBox fx:id="chartScaleCombo" prefWidth="120.0" style="-fx-background-radius: 8; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-font-size: 11;" />
                              <Button onAction="#generatePDF" style="-fx-background-color: #063D2F; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 11; -fx-font-weight: bold; -fx-cursor: hand;" text="📄 PDF" />
                           </children>
                        </HBox>
                        <BarChart fx:id="revenueTrendChart" animated="false" barGap="5.0" categoryGap="20.0" prefHeight="400.0" style="-fx-opacity: 0.9;" verticalGridLinesVisible="false">
                           <xAxis><CategoryAxis side="BOTTOM" tickLabelFill="#64748B" /></xAxis>
                           <yAxis><NumberAxis side="LEFT" tickLabelFill="#64748B" /></yAxis>
                        </BarChart>
                     </children>
                  </VBox>

                  <VBox prefWidth="400.0" spacing="15.0">
                     <children>
                        <!-- Solde des Budgets (Wallets) -->
                        <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 25; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 8);">
                           <children>
                              <Label text="📊  Solde des Budgets" textFill="#063D2F">
                                 <font><Font name="System Bold" size="16.0" /></font>
                              </Label>
                              <VBox fx:id="walletProgressVBox" spacing="10.0" />
                           </children>
                        </VBox>
                        
                        <!-- Dernières Transactions -->
                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 25; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 8);">
                           <children>
                              <Label text="📋  Dernières Transactions" textFill="#063D2F">
                                 <font><Font name="System Bold" size="16.0" /></font>
                              </Label>
                              <VBox fx:id="recentTransactionsVBox" spacing="8.0" />
                           </children>
                        </VBox>

                        <!-- DETAIL SOURCES CARD -->
                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 25; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 8);" VBox.vgrow="ALWAYS">
                           <children>
                              <Label text="Sources de Capital" textFill="#063D2F"><font><Font name="System Bold" size="16.0" /></font></Label>
                              <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
                                 <content>
                                    <VBox fx:id="sourcesListVBox" spacing="10.0" />
                                 </content>
                              </ScrollPane>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</AnchorPane>
