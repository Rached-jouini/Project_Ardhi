<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="720.0" prefWidth="1000.0" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LocationEquipementController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            
            <!-- Header Section -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 20 30 10 30;">
               <children>
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Catalogue Location" textFill="#1E293B">
                           <font><Font name="System Bold" size="28.0" /></font>
                        </Label>
                        <Label text="Louez le meilleur matériel pour votre ferme" textFill="#64748B" />
                     </children>
                  </VBox>
                  
                  <HBox alignment="CENTER" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 25; -fx-padding: 10 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                     <children>
                        <Label text="🔍" textFill="#64748B" />
                        <TextField fx:id="searchField" onKeyReleased="#search" prefWidth="250.0" promptText="Rechercher un équipement..." style="-fx-background-color: transparent; -fx-font-size: 14;" />
                     </children>
                  </HBox>
                  
                  <StackPane style="-fx-cursor: hand;">
                     <children>
                        <Label fx:id="cartBtn" style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" text="🛒">
                           <font><Font size="18.0" /></font>
                        </Label>
                        <Circle fill="#EF4444" radius="10.0" stroke="WHITE" strokeType="INSIDE" strokeWidth="2.0" StackPane.alignment="TOP_RIGHT">
                           <StackPane.margin><Insets right="-5.0" top="-5.0" /></StackPane.margin>
                        </Circle>
                        <Label fx:id="cartCountLabel" text="0" textFill="WHITE" StackPane.alignment="TOP_RIGHT">
                           <font><Font name="System Bold" size="10.0" /></font>
                           <StackPane.margin><Insets right="0.0" top="-2.0" /></StackPane.margin>
                        </Label>
                     </children>
                  </StackPane>
               </children>
            </HBox>

            <!-- Categories Section -->
            <HBox spacing="15.0" style="-fx-padding: 0 30;">
               <children>
                  <Button mnemonicParsing="false" onAction="#filterAll" style="-fx-background-color: #063D2F; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;" text="Tous" />
                  <Button mnemonicParsing="false" onAction="#filterTracteurs" style="-fx-background-color: white; -fx-text-fill: #64748B; -fx-background-radius: 20; -fx-padding: 8 20; -fx-border-color: #E2E8F0; -fx-border-radius: 20; -fx-cursor: hand;" text="Tracteurs" />
                  <Button mnemonicParsing="false" onAction="#filterOutils" style="-fx-background-color: white; -fx-text-fill: #64748B; -fx-background-radius: 20; -fx-padding: 8 20; -fx-border-color: #E2E8F0; -fx-border-radius: 20; -fx-cursor: hand;" text="Outils" />
                  <Button mnemonicParsing="false" onAction="#filterIrrigation" style="-fx-background-color: white; -fx-text-fill: #64748B; -fx-background-radius: 20; -fx-padding: 8 20; -fx-border-color: #E2E8F0; -fx-border-radius: 20; -fx-cursor: hand;" text="Irrigation" />
                  <Button mnemonicParsing="false" onAction="#filterDrones" style="-fx-background-color: white; -fx-text-fill: #64748B; -fx-background-radius: 20; -fx-padding: 8 20; -fx-border-color: #E2E8F0; -fx-border-radius: 20; -fx-cursor: hand;" text="Drones" />
               </children>
            </HBox>

            <!-- Catalogue Grid -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
               <content>
                  <FlowPane fx:id="cataloguePane" hgap="25.0" vgap="25.0">
                     <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="10.0" />
                     </padding>
                     <!-- Cards will be added here dynamically -->
                  </FlowPane>
               </content>
            </ScrollPane>
            
         </children>
      </VBox>
   </children>
</AnchorPane>
