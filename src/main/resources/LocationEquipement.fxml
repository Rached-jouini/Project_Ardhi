<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Circle?>

<ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" styleClass="root-pane" stylesheets="@ardhi.css" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LocationEquipementController">
    <content>
        <BorderPane style="-fx-background-color: transparent;">
            
            <!-- Sidebar Gauche -->
            <left>
                <VBox prefWidth="270" spacing="16" styleClass="sidebar">
                    <padding>
                        <Insets top="28" right="22" bottom="28" left="22"/>
                    </padding>
                    <Label text="Ardhi" styleClass="sidebar-title"/>
                    <Label text="Location Materiel" styleClass="sidebar-section-title" wrapText="true"/>
                    
                    <VBox spacing="10" styleClass="sidebar-panel">
                        <Label text="Navigation" styleClass="sidebar-panel-title"/>
                        <Button text="Retour Accueil" onAction="#handleBackHome" styleClass="sidebar-nav-button" maxWidth="1.7976931348623157E308"/>
                    </VBox>
                    
                    <VBox spacing="10" styleClass="sidebar-panel">
                        <Label text="Ma Selection" styleClass="sidebar-panel-title"/>
                        <Button text="Mon Panier" onAction="#handleOpenCart" styleClass="sidebar-nav-button" maxWidth="1.7976931348623157E308"/>
                        <Button text="Mes Locations" onAction="#handleOpenTransactions" styleClass="sidebar-nav-button" maxWidth="1.7976931348623157E308"/>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS"/>
                    <VBox alignment="CENTER" spacing="10" style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 15; -fx-background-radius: 15;">
                        <Label fx:id="cartCountLabel" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #10B981;"/>
                        <Label text="Articles au panier" style="-fx-font-size: 11; -fx-text-fill: white; -fx-opacity: 0.7;"/>
                    </VBox>
                </VBox>
            </left>

            <center>
                <VBox spacing="24" styleClass="content-box">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <!-- Header Card -->
                    <VBox spacing="15" styleClass="admin-header-card">
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Catalogue des Equipements" styleClass="page-title" textFill="WHITE"/>
                                <Label text="Louez du materiel de pointe pour optimiser vos rendements agricoles." 
                                       wrapText="true" styleClass="auth-subtitle" textFill="WHITE"/>
                            </VBox>
                            <HBox alignment="CENTER" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 8 15; -fx-min-width: 300;">
                                <children>
                                    <Label text="🔍" style="-fx-font-size: 16;"/>
                                    <TextField fx:id="searchField" onKeyReleased="#search" promptText="Rechercher un outil..." style="-fx-background-color: transparent; -fx-font-size: 14;" HBox.hgrow="ALWAYS" />
                                </children>
                            </HBox>
                        </HBox>
                    </VBox>

                    <!-- Categories Row -->
                    <HBox spacing="12.0">
                        <children>
                            <Button onAction="#filterAll" styleClass="btn-primary" text="Tous" prefHeight="40"/>
                            <Button onAction="#filterTracteurs" styleClass="btn-secondary" text="Tracteurs" prefHeight="40"/>
                            <Button onAction="#filterOutils" styleClass="btn-secondary" text="Outils" prefHeight="40"/>
                            <Button onAction="#filterIrrigation" styleClass="btn-secondary" text="Irrigation" prefHeight="40"/>
                            <Button onAction="#filterDrones" styleClass="btn-secondary" text="Drones" prefHeight="40"/>
                        </children>
                    </HBox>

                    <!-- Catalogue Grid -->
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                        <content>
                            <FlowPane fx:id="cataloguePane" hgap="24.0" vgap="24.0">
                                <padding>
                                    <Insets bottom="30.0" top="10.0" />
                                </padding>
                                <!-- Les cartes d'équipements seront ajoutées ici -->
                            </FlowPane>
                        </content>
                    </ScrollPane>
                </VBox>
            </center>
        </BorderPane>
    </content>
</ScrollPane>
