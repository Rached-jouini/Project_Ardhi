<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1100.0" style="-fx-background-color: #F3F4F6;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.GestionEquipementController">
   <children>
      <VBox spacing="25.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
         <children>
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#retourAccueil" style="-fx-background-color: #E5E7EB; -fx-background-radius: 10; -fx-padding: 8 15;" text="🏠 Accueil" />
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Inventaire des Équipements" textFill="#2d5d34">
                           <font>
                              <Font name="System Bold" size="28.0" />
                           </font>
                        </Label>
                        <Label text="Gestion du stock et aperçu visuel du matériel" textFill="#6b7280" />
                     </children>
                  </VBox>
                  <Button mnemonicParsing="false" onAction="#ouvrirFormulaireAjout" style="-fx-background-color: #2d5d34; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-padding: 10 20;" text="+ Nouvel Équipement" />
               </children>
            </HBox>

            <!-- Barre de Recherche -->
            <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 5);">
               <children>
                  <TextField fx:id="rechercheField" prefHeight="35.0" prefWidth="400.0" promptText="Rechercher par nom ou type..." style="-fx-background-radius: 10; -fx-border-color: #E5E7EB; -fx-border-radius: 10;" />
               </children>
            </HBox>

            <!-- Table des Équipements -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 8);" VBox.vgrow="ALWAYS">
               <children>
                  <TableView fx:id="equipementTable" prefHeight="400.0" style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colNom" prefWidth="180.0" text="Nom" />
                      <TableColumn fx:id="colType" prefWidth="120.0" text="Type" />
                      <TableColumn fx:id="colQteTotale" prefWidth="100.0" text="Qté Totale" />
                      <TableColumn fx:id="colQteDispo" prefWidth="100.0" text="Qté Dispo" />
                      <TableColumn fx:id="colEtat" prefWidth="100.0" text="État" />
                      <TableColumn fx:id="colPhoto" prefWidth="100.0" text="Photo" />
                      <TableColumn fx:id="colPrix" prefWidth="120.0" text="Prix/Jour (DT)" />
                      <TableColumn fx:id="colActions" prefWidth="150.0" text="Actions" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
