<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="root-pane" stylesheets="@ardhi.css" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.GestionEquipementController">
    <content>
        <BorderPane style="-fx-background-color: transparent;">
            
            <!-- Sidebar Gauche -->
            <left>
                <VBox prefWidth="270" spacing="16" styleClass="sidebar">
                    <padding>
                        <Insets top="28" right="22" bottom="28" left="22"/>
                    </padding>
                    <Label text="Ardhi" styleClass="sidebar-title"/>
                    <Label text="Gestion Equipements" styleClass="sidebar-section-title" wrapText="true"/>
                    
                    <VBox spacing="10" styleClass="sidebar-panel">
                        <Label text="Raccourcis" styleClass="sidebar-panel-title"/>
                        <Button text="Tableau de Bord" onAction="#retourAccueil" styleClass="sidebar-nav-button" maxWidth="1.7976931348623157E308"/>
                    </VBox>
                    
                    <Region VBox.vgrow="ALWAYS"/>
                    <Label text="Inventaire &amp; Stock" styleClass="feature-pill"/>
                </VBox>
            </left>

            <center>
                <VBox spacing="24" styleClass="content-box">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <!-- Header Card -->
                    <VBox spacing="12" styleClass="admin-header-card">
                        <Label text="Inventaire des Equipements" styleClass="page-title" textFill="WHITE"/>
                        <Label text="Suivez l'etat de votre materiel, gerez les stocks disponibles et planifiez les remplacements de vos outils de travail." 
                               wrapText="true" styleClass="auth-subtitle" textFill="WHITE"/>
                        <HBox spacing="10">
                            <Label text="Tracteurs" styleClass="admin-chip"/>
                            <Label text="Outils" styleClass="admin-chip"/>
                            <Label text="Drones &amp; Capteurs" styleClass="admin-chip"/>
                        </HBox>
                    </VBox>

                    <!-- Main Table Section -->
                    <VBox spacing="20" styleClass="card">
                        <padding>
                            <Insets top="24" right="24" bottom="24" left="24"/>
                        </padding>
                        
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <children>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Materiel et Outillage" styleClass="section-title"/>
                                    <TextField fx:id="rechercheField" promptText="Rechercher par nom ou type..." prefHeight="40" maxWidth="400"/>
                                </VBox>
                                <Button text="+ Nouvel Equipement" onAction="#ouvrirFormulaireAjout" styleClass="btn-primary" prefHeight="45"/>
                            </children>
                        </HBox>

                        <Separator opacity="0.4"/>

                        <TableView fx:id="equipementTable" prefHeight="500.0" styleClass="table-compact" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colNom" prefWidth="180.0" text="Nom" />
                                <TableColumn fx:id="colType" prefWidth="120.0" text="Type" />
                                <TableColumn fx:id="colQteTotale" prefWidth="100.0" text="Qte Totale" />
                                <TableColumn fx:id="colQteDispo" prefWidth="100.0" text="Qte Dispo" />
                                <TableColumn fx:id="colEtat" prefWidth="100.0" text="Etat" />
                                <TableColumn fx:id="colPhoto" prefWidth="100.0" text="Photo" />
                                <TableColumn fx:id="colPrix" prefWidth="120.0" text="Prix/Jour (DT)" />
                                <TableColumn fx:id="colActions" prefWidth="150.0" text="Actions" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </VBox>
            </center>
        </BorderPane>
    </content>
</ScrollPane>
