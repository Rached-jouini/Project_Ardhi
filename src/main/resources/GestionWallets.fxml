<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="750.0" prefWidth="1100.0" style="-fx-background-color: #F3F4F6;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.GestionWalletsController">
   <children>
      <VBox spacing="25.0" AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="25.0">
         <children>
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Button onAction="#retourDashboard" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 10 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);" text="⬅️ Retour Dashboard" />
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Gestion des Budgets (Wallets)" textFill="#063D2F">
                           <font><Font name="System Bold" size="26.0" /></font>
                        </Label>
                        <Label text="Allouez votre capital a des enveloppes budgetaires intelligentes" textFill="#6B7280" />
                     </children>
                  </VBox>
                  <Button onAction="#ouvrirAjoutWallet" style="-fx-background-color: #063D2F; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-weight: bold; -fx-padding: 12 25;" text="+ Creer un Budget" />
               </children>
            </HBox>

            <!-- Wallets Grid -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
               <content>
                  <FlowPane fx:id="walletsFlowPane" hgap="25.0" vgap="25.0">
                     <padding><Insets bottom="20.0" left="5.0" right="20.0" top="20.0" /></padding>
                  </FlowPane>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
