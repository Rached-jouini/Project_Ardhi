<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="500.0" prefWidth="700.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ReserverTerrainController">
   <center>
      <VBox alignment="CENTER" spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <VBox maxWidth="500.0" spacing="20.0" styleClass="card">
               <children>
                  <Label styleClass="title-page" text="Finaliser votre Location" />
                  
                  <VBox spacing="10.0">
                     <children>
                        <Label fx:id="terrainInfoLabel" text="Terrain à [Région] - [Superficie] m²" style="-fx-font-weight: bold; -fx-text-fill: #2D5D34;" />
                        <Label fx:id="prixLabel" text="Prix mensuel : 0.00 TND" styleClass="label-standard" />
                     </children>
                  </VBox>

                  <HBox spacing="20.0">
                     <children>
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="label-standard" text="Date de début" />
                              <DatePicker fx:id="dateDebutPicker" maxWidth="1.7976931348623157E308" />
                           </children>
                        </VBox>
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="label-standard" text="Date de fin" />
                              <DatePicker fx:id="dateFinPicker" maxWidth="1.7976931348623157E308" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <HBox alignment="CENTER_RIGHT" spacing="15.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#annuler" style="-fx-background-color: transparent; -fx-text-fill: #6B7280;" text="Annuler" />
                        <Button mnemonicParsing="false" onAction="#confirmerLocation" styleClass="button-secondary" text="Confirmer la Location" />
                     </children>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </HBox>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>
