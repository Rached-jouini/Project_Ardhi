<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="480.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 20;" stylesheets="@ardhi.css" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.FormulaireWalletController">
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
   <children>
      <!-- Header Section -->
      <VBox spacing="8.0">
         <children>
            <Label text="🎯 Nouveau Budget" styleClass="auth-title">
               <font><Font name="System Bold" size="22.0" /></font>
            </Label>
            <Label text="Creez une enveloppe budgetaire pour vos projets (Semences, Main d'œuvre, etc.)" styleClass="auth-subtitle" wrapText="true" />
         </children>
      </VBox>

      <Separator opacity="0.4" />

      <!-- Form Fields (Scrollable if needed) -->
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
         <content>
            <VBox spacing="18.0">
               <children>
                  <VBox spacing="8.0">
                     <children>
                        <Label text="Nom du budget" styleClass="field-label" />
                        <TextField fx:id="nomField" prefHeight="45.0" promptText="Ex: Engrais, Salaires, Maintenance..." styleClass="text-field" />
                     </children>
                  </VBox>

                  <VBox spacing="8.0">
                     <children>
                        <Label text="Montant Alloue (DT)" styleClass="field-label" />
                        <TextField fx:id="montantField" prefHeight="45.0" promptText="0.00" styleClass="text-field" />
                     </children>
                  </VBox>

                  <VBox spacing="8.0">
                     <children>
                        <Label text="Limite de Decouvert Autorise (DT)" styleClass="field-label" style="-fx-text-fill: #dc2626;" />
                        <TextField fx:id="decouvertField" prefHeight="45.0" promptText="0.00" styleClass="text-field" text="0.00" />
                        <Label text="Permet de depenser au-dela du budget (ex: 500 DT)" styleClass="helper-label" />
                     </children>
                  </VBox>

                  <VBox spacing="8.0">
                     <children>
                        <Label text="Description" styleClass="field-label" />
                        <TextArea fx:id="descField" prefHeight="100.0" promptText="Precisez l'usage de ce budget..." styleClass="text-area" wrapText="true" />
                     </children>
                  </VBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>

      <Region VBox.vgrow="ALWAYS" />

      <!-- Action Button -->
      <Button fx:id="btnAction" onAction="#enregistrerWallet" maxWidth="1.7976931348623157E308" prefHeight="50.0" styleClass="btn-primary" text="CREER LE BUDGET" />
   </children>
</VBox>
