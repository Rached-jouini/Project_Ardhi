<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" styleClass="root-pane" stylesheets="@ardhi.css" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PanierController">
    <content>
        <BorderPane style="-fx-background-color: transparent;">
            
            <!-- Sidebar Gauche -->
            <left>
                <VBox prefWidth="270" spacing="16" styleClass="sidebar">
                    <padding>
                        <Insets top="28" right="22" bottom="28" left="22"/>
                    </padding>
                    <Label text="Ardhi" styleClass="sidebar-title"/>
                    <Label text="Mon Panier" styleClass="sidebar-section-title" wrapText="true"/>
                    
                    <VBox spacing="10" styleClass="sidebar-panel">
                        <Label text="Navigation" styleClass="sidebar-panel-title"/>
                        <Button text="Retour Catalogue" onAction="#close" styleClass="sidebar-nav-button" maxWidth="1.7976931348623157E308"/>
                        <Button text="Retour Accueil" onAction="#handleBackHome" styleClass="sidebar-nav-button" maxWidth="1.7976931348623157E308"/>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS"/>
                    <VBox alignment="CENTER" spacing="10" style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 15; -fx-background-radius: 15;">
                        <Label fx:id="cartSummaryLabel" text="0 article(s)" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #10B981;"/>
                        <Label text="Pret pour la validation" style="-fx-font-size: 11; -fx-text-fill: white; -fx-opacity: 0.7;"/>
                    </VBox>
                </VBox>
            </left>

            <center>
                <VBox spacing="24" styleClass="content-box">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <!-- Header Card -->
                    <VBox spacing="12" styleClass="admin-header-card">
                        <Label text="Validation de votre Location" styleClass="page-title" textFill="WHITE"/>
                        <Label text="Verifiez vos articles, selectionnez vos dates et votre mode de paiement pour finaliser la reservation." 
                               wrapText="true" styleClass="auth-subtitle" textFill="WHITE"/>
                    </VBox>

                    <HBox spacing="25.0">
                        <children>
                            <!-- LEFT: ARTICLES LIST -->
                            <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                                <children>
                                    <VBox spacing="15.0" styleClass="card">
                                        <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>
                                        <children>
                                            <Label text="🛒 Articles selectionnes" styleClass="section-title"/>
                                            <Separator opacity="0.3"/>
                                            <VBox fx:id="cartItemsContainer" spacing="12.0">
                                                <!-- Articles dynamiques -->
                                            </VBox>
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>

                            <!-- RIGHT: CHECKOUT FORM -->
                            <VBox minWidth="450.0" prefWidth="450.0" spacing="20.0">
                                <children>
                                    <!-- Date Selection -->
                                    <VBox spacing="15.0" styleClass="card">
                                        <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>
                                        <children>
                                            <Label text="📅 Periode de Location" styleClass="section-title"/>
                                            <HBox spacing="15.0">
                                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                                    <Label text="Date Debut" styleClass="field-label" />
                                                    <DatePicker fx:id="dateDebutPicker" maxWidth="1.7976931348623157E308" prefHeight="45.0" />
                                                </VBox>
                                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                                    <Label text="Date Fin" styleClass="field-label" />
                                                    <DatePicker fx:id="dateFinPicker" maxWidth="1.7976931348623157E308" prefHeight="45.0" />
                                                </VBox>
                                            </HBox>
                                            <HBox alignment="CENTER" spacing="8" style="-fx-background-color: #EFF6FF; -fx-padding: 10; -fx-background-radius: 10;">
                                                <Label fx:id="durationLabel" text="Duree : 1 jour(s)" style="-fx-text-fill: #1D4ED8; -fx-font-weight: bold;"/>
                                            </HBox>
                                        </children>
                                    </VBox>

                                    <!-- Payment Details -->
                                    <VBox spacing="15.0" styleClass="card">
                                        <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>
                                        <children>
                                            <Label text="💰 Paiement et Budget" styleClass="section-title"/>
                                            
                                            <VBox spacing="8.0">
                                                <Label text="Budget a impacter (Wallet)" styleClass="field-label" />
                                                <ComboBox fx:id="walletSelectionCombo" maxWidth="1.7976931348623157E308" prefHeight="45.0" />
                                                <Label fx:id="walletBalanceLabel" text="Solde: —" styleClass="muted-label" />
                                            </VBox>

                                            <VBox spacing="8.0">
                                                <Label text="Mode de Paiement" styleClass="field-label" />
                                                <ComboBox fx:id="paiementCombo" maxWidth="1.7976931348623157E308" prefHeight="45.0" />
                                            </VBox>

                                            <!-- Section Carte (Conditionnelle) -->
                                            <VBox fx:id="carteBancaireSection" spacing="10.0" managed="false" visible="false"
                                                  style="-fx-background-color: #F0FDF4; -fx-padding: 15; -fx-background-radius: 12; -fx-border-color: #10B981; -fx-border-width: 1;">
                                                <Label text="Selectionner votre carte" styleClass="field-label" textFill="#065F46" />
                                                <ComboBox fx:id="carteCombo" maxWidth="1.7976931348623157E308" prefHeight="45.0" />
                                                <Label fx:id="soldCarteLabel" text="Solde carte: —" style="-fx-font-weight: bold;" textFill="#059669" />
                                            </VBox>

                                            <Separator opacity="0.3"/>

                                            <HBox alignment="CENTER_LEFT">
                                                <VBox>
                                                    <Label text="TOTAL A PAYER" styleClass="muted-label" />
                                                    <Label fx:id="totalLabel" text="0.00 DT" style="-fx-font-size: 32; -fx-font-weight: 900;" textFill="#063D2F" />
                                                </VBox>
                                            </HBox>

                                            <Button fx:id="confirmBtn" onAction="#validerLocation" prefHeight="60.0" maxWidth="1.7976931348623157E308" 
                                                    styleClass="btn-primary" text="🚀 CONFIRMER LA LOCATION" />
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>
                        </children>
                    </HBox>
                </VBox>
            </center>
        </BorderPane>
    </content>
</ScrollPane>
