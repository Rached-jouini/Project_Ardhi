<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1150.0" styleClass="root-pane" stylesheets="@ardhi.css" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AdminGestionBudgetsController">
    
    <!-- Sidebar Admin -->
    <left>
        <VBox prefWidth="270" spacing="16" styleClass="sidebar">
            <padding>
                <Insets top="28" right="22" bottom="28" left="22"/>
            </padding>
            <Label text="Ardhi" styleClass="sidebar-title"/>
            <Label text="Administration" styleClass="sidebar-section-title" wrapText="true"/>
            
            <VBox spacing="10" styleClass="sidebar-panel">
                <Label text="Navigation" styleClass="sidebar-panel-title"/>
                <Button text="Dashboard Admin" onAction="#handleBackToDashboard" styleClass="sidebar-nav-button" maxWidth="1.7976931348623157E308"/>
            </VBox>
            
            <Region VBox.vgrow="ALWAYS"/>
            <Label text="Mode Administrateur" styleClass="feature-pill" style="-fx-background-color: #FEE2E2; -fx-text-fill: #991B1B;"/>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <content>
                <VBox spacing="30" styleClass="content-box">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <!-- Header Card -->
                    <VBox spacing="12" styleClass="admin-header-card">
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Gestion des Budgets et Wallets" styleClass="page-title" textFill="WHITE"/>
                                <Label text="Configurez les enveloppes budgetaires allouees aux differents departements et services." 
                                       wrapText="true" styleClass="auth-subtitle" textFill="WHITE"/>
                            </VBox>
                            <Button text="+ Nouveau Budget" onAction="#ouvrirAjoutWallet" styleClass="btn-primary" prefHeight="45" style="-fx-background-color: #2D6A4F;"/>
                        </HBox>
                    </VBox>

                    <!-- SECTION UNIQUE: BUDGETS (WALLETS) -->
                    <VBox spacing="20" styleClass="card" VBox.vgrow="ALWAYS">
                        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                        <VBox spacing="4">
                            <Label text="📊 Liste des Enveloppes Budgetaires" styleClass="section-title"/>
                            <Label text="Visualisez, modifiez ou supprimez les budgets du systeme." styleClass="muted-label"/>
                        </VBox>
                        <Separator/>
                        <FlowPane fx:id="walletsFlowPane" hgap="24" vgap="24">
                            <!-- Les cartes de budgets seront ajoutées ici par le contrôleur -->
                        </FlowPane>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
