<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" styleClass="root-pane" stylesheets="@ardhi.css" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.TransactionsViewController">
    <content>
        <BorderPane style="-fx-background-color: transparent;">
            
            <!-- Sidebar Gauche (Style Finance) -->
            <left>
                <VBox prefWidth="270" spacing="16" styleClass="sidebar">
                    <padding>
                        <Insets top="28" right="22" bottom="28" left="22"/>
                    </padding>
                    <Label text="Ardhi" styleClass="sidebar-title"/>
                    <Label text="Mes Transactions" styleClass="sidebar-section-title" wrapText="true"/>
                    
                    <VBox spacing="10" styleClass="sidebar-panel">
                        <Label text="Navigation" styleClass="sidebar-panel-title"/>
                        <Button text="Tableau de bord Finance" onAction="#handleBackToDashboard" styleClass="sidebar-nav-button" maxWidth="1.7976931348623157E308"/>
                        <Button text="Retour Accueil" onAction="#handleBackToHome" styleClass="sidebar-nav-button" maxWidth="1.7976931348623157E308"/>
                    </VBox>
                    
                    <VBox spacing="10" styleClass="sidebar-panel">
                        <Label text="Finance" styleClass="sidebar-panel-title"/>
                        <Button text="Comptes et Cartes" onAction="#handleOpenWallets" styleClass="sidebar-nav-button" maxWidth="1.7976931348623157E308"/>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS"/>
                    <Label text="Suivi securise" styleClass="feature-pill"/>
                </VBox>
            </left>

            <center>
                <VBox spacing="24" styleClass="content-box">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <!-- Header Card -->
                    <VBox spacing="12" styleClass="admin-header-card">
                        <Label text="Historique des Transactions" styleClass="page-title" textFill="WHITE"/>
                        <Label text="Enregistrez vos nouvelles operations et suivez l'evolution de vos flux financiers en temps reel." 
                               wrapText="true" styleClass="auth-subtitle" textFill="WHITE"/>
                    </VBox>

                    <HBox spacing="25.0">
                        <children>
                            <!-- LEFT: FORMULAIRE -->
                            <VBox minWidth="500.0" prefWidth="500.0" spacing="20.0" styleClass="card">
                                <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
                                <children>
                                    <Label text="💸 Nouvelle Operation" styleClass="section-title"/>
                                    
                                    <VBox spacing="10.0">
                                        <children>
                                            <Label text="Type de flux" styleClass="field-label" />
                                            <HBox spacing="15.0">
                                                <children>
                                                    <ToggleButton fx:id="btnRevenu" maxWidth="1.7976931348623157E308" prefHeight="50.0" selected="true" style="-fx-background-color: #ECFDF5; -fx-text-fill: #059669; -fx-background-radius: 12; -fx-font-weight: bold; -fx-cursor: hand;" text="🟢 REVENU" HBox.hgrow="ALWAYS">
                                                        <toggleGroup><ToggleGroup fx:id="typeGroup" /></toggleGroup>
                                                    </ToggleButton>
                                                    <ToggleButton fx:id="btnDepense" maxWidth="1.7976931348623157E308" prefHeight="50.0" style="-fx-background-color: #FEE2E2; -fx-text-fill: #EF4444; -fx-background-radius: 12; -fx-font-weight: bold; -fx-cursor: hand;" text="🔴 DEPENSE" toggleGroup="$typeGroup" HBox.hgrow="ALWAYS" />
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>

                                    <VBox spacing="8.0">
                                        <children>
                                            <Label text="Montant (DT)" styleClass="field-label" />
                                            <TextField fx:id="montantField" prefHeight="50.0" promptText="0.00" style="-fx-font-size: 18; -fx-font-weight: bold;" />
                                        </children>
                                    </VBox>

                                    <HBox spacing="15.0">
                                        <children>
                                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label text="Budget / Wallet" styleClass="field-label" />
                                                    <ComboBox fx:id="walletCombo" maxWidth="1.7976931348623157E308" prefHeight="45.0" />
                                                </children>
                                            </VBox>
                                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label text="Mode de Paiement" styleClass="field-label" />
                                                    <ComboBox fx:id="modePaiementCombo" maxWidth="1.7976931348623157E308" prefHeight="45.0" />
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <VBox spacing="8.0">
                                        <children>
                                            <Label text="📱 Notification SMS (Optionnel)" styleClass="field-label" />
                                            <HBox spacing="10.0">
                                                <children>
                                                    <ComboBox fx:id="prefixCombo" prefHeight="45.0" prefWidth="100.0" />
                                                    <TextField fx:id="phoneField" prefHeight="45.0" promptText="Numero de telephone" HBox.hgrow="ALWAYS" />
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>

                                    <VBox spacing="8.0">
                                        <children>
                                            <Label text="Description" styleClass="field-label" />
                                            <TextArea fx:id="descField" prefHeight="80.0" promptText="Notes sur l'operation..." wrapText="true" />
                                        </children>
                                    </VBox>

                                    <Button onAction="#handleEnregistrer" prefHeight="55.0" maxWidth="1.7976931348623157E308" styleClass="btn-primary" text="🚀 VALIDER LA TRANSACTION" />
                                </children>
                            </VBox>

                            <!-- RIGHT: HISTORIQUE -->
                            <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                                <children>
                                    <VBox spacing="15.0" styleClass="card">
                                        <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>
                                        <children>
                                            <HBox alignment="CENTER_LEFT">
                                                <children>
                                                    <VBox>
                                                        <Label text="Historique Recent" styleClass="section-title"/>
                                                        <Label text="Suivi de vos activites financieres" styleClass="muted-label" />
                                                    </VBox>
                                                    <Region HBox.hgrow="ALWAYS" />
                                                    <Button styleClass="btn-secondary" text="🔍 Filtrer" />
                                                </children>
                                            </HBox>
                                            
                                            <Separator opacity="0.3"/>
                                            
                                            <VBox fx:id="historyContainer" spacing="12.0">
                                                <!-- Cartes de transactions dynamiques -->
                                            </VBox>
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>
                        </children>
                    </HBox>
                </VBox>
            </center>
        </BorderPane>
    </content>
</ScrollPane>
