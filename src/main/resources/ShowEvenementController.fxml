<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ShowEvenementController">
   
   <!-- Sidebar Navigation -->
   <left>
      <VBox styleClass="sidebar">
         <children>
            <Label styleClass="sidebar-title" text="Ardhi Project" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-button, sidebar-button-active" text="📅 Événements" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-button" text="🌾 Cultures" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-button" text="📈 Statistiques" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-button" text="⚙️ Paramètres" />
            <Region VBox.vgrow="ALWAYS" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-button" text="🚪 Déconnexion" />
         </children>
      </VBox>
   </left>

   <!-- Main Content Area -->
   <center>
      <VBox styleClass="content-pane">
         <children>
            <Label styleClass="title-label" text="Détails de l'Événement" />
            
            <VBox styleClass="card" spacing="20.0">
               <children>
                  <GridPane hgap="30.0" vgap="15.0">
                    <columnConstraints>
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="400.0" />
                    </columnConstraints>
                    <rowConstraints>
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2D5D34;" text="Nom :" />
                        <Label fx:id="nom" style="-fx-font-size: 16px;" text="Label" GridPane.columnIndex="1" />
                        
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2D5D34;" text="Description :" GridPane.rowIndex="1" />
                        <Label fx:id="description" style="-fx-font-size: 14px;" text="Label" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2D5D34;" text="Date :" GridPane.rowIndex="2" />
                        <Label fx:id="date" style="-fx-font-size: 14px;" text="Label" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2D5D34;" text="Lieu :" GridPane.rowIndex="3" />
                        <Label fx:id="lieu" style="-fx-font-size: 14px;" text="Label" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2D5D34;" text="Type :" GridPane.rowIndex="4" />
                        <Label fx:id="type" style="-fx-font-size: 14px;" text="Label" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                        
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2D5D34;" text="Culture concernée :" GridPane.rowIndex="5" />
                        <Label fx:id="culture" style="-fx-font-size: 14px;" text="Label" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                        
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2D5D34;" text="Nombre de places :" GridPane.rowIndex="6" />
                        <Label fx:id="places" style="-fx-font-size: 14px;" text="Label" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                        
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2D5D34;" text="Statut :" GridPane.rowIndex="7" />
                        <Label fx:id="statut" style="-fx-font-size: 14px;" text="Label" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                     </children>
                  </GridPane>
                  
                  <HBox alignment="CENTER_RIGHT">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleRetour" styleClass="btn-primary" text="Retour à la liste" />
                     </children>
                     <VBox.margin>
                        <Insets top="20.0" />
                     </VBox.margin>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </center>
</BorderPane>
