<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AjouterPlanteController">
   <left>
      <VBox prefWidth="240.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="sidebar-title" text="Ardhi Admin" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#allerVersTerrains" styleClass="sidebar-button" text="Gestion Terrains" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-button, sidebar-button-active" text="Gestion Plantes" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-button" text="Équipements" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-button" text="Finances" />
         </children>
      </VBox>
   </left>
   <center>
      <ScrollPane fitToWidth="true" styleClass="scroll-pane" BorderPane.alignment="CENTER">
         <content>
            <VBox spacing="30.0">
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label fx:id="mainTitle" styleClass="title-page" text="Ajouter une Nouvelle Plante" />
                        <Label styleClass="label-standard" text="Enregistrez les caractéristiques et les besoins de cette espèce." />
                     </children>
                  </VBox>
                  
                  <VBox maxWidth="600.0" spacing="20.0" styleClass="card">
                     <children>
                        <HBox spacing="20.0">
                           <children>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="label-standard" text="Nom de la Plante" />
                                    <TextField fx:id="nom_p" promptText="Ex: Olive, Tomate..." styleClass="text-field" />
                                 </children>
                              </VBox>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="label-standard" text="Type / Catégorie" />
                                    <TextField fx:id="type_p" promptText="Légume, Fruitier..." styleClass="text-field" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        
                        <HBox spacing="20.0">
                           <children>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="label-standard" text="Début Plantation" />
                                    <DatePicker fx:id="date_debut_p" maxWidth="1.7976931348623157E308" styleClass="text-field" />
                                 </children>
                              </VBox>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="label-standard" text="Fin Plantation" />
                                    <DatePicker fx:id="date_fin_p" maxWidth="1.7976931348623157E308" styleClass="text-field" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        
                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="label-standard" text="Besoin en Eau" />
                              <TextField fx:id="besoin_eau_p" promptText="Faible, Moyen, Élevé..." styleClass="text-field" />
                           </children>
                        </VBox>
                        
                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="label-standard" text="Description" />
                              <TextField fx:id="description_p" promptText="Détails supplémentaires..." styleClass="text-field" />
                           </children>
                        </VBox>
                        
                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#retourListe" style="-fx-background-color: transparent; -fx-text-fill: #6B7280;" text="Annuler" />
                              <Button fx:id="btnSave" mnemonicParsing="false" onAction="#save_plante" styleClass="button-primary" text="Enregistrer la Plante" />
                           </children>
                           <padding>
                              <Insets top="10.0" />
                           </padding>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
