<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" styleClass="root-pane" stylesheets="@ardhi.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AjouterPlanteController">
   <left>
      <VBox prefWidth="270.0" spacing="16" styleClass="sidebar" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="28.0" left="22.0" right="22.0" top="28.0" />
         </padding>
         <children>
            <Label styleClass="sidebar-title" text="Ardhi" />
            <Label text="Édition Plante" styleClass="sidebar-section-title"/>
            <VBox spacing="10" styleClass="sidebar-panel">
                <Label text="Raccourcis" styleClass="sidebar-panel-title"/>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#retourListe" styleClass="sidebar-nav-button" text="⬅ Retour à la liste" />
            </VBox>
         </children>
      </VBox>
   </left>
   <center>
      <ScrollPane fitToWidth="true" styleClass="content-scroll" BorderPane.alignment="CENTER">
         <content>
            <VBox spacing="30.0" styleClass="content-box">
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
               <children>
                  <VBox spacing="12" styleClass="admin-header-card">
                     <children>
                        <Label fx:id="mainTitle" styleClass="page-title" text="Ajouter une Nouvelle Plante" />
                        <Label styleClass="auth-subtitle" text="Enregistrez les caractéristiques et les besoins de cette espèce." />
                     </children>
                  </VBox>
                  
                  <VBox maxWidth="600.0" spacing="20.0" styleClass="card">
                     <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                     </padding>
                     <children>
                        <HBox spacing="20.0">
                           <children>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="field-label" text="Nom de la Plante" />
                                    <TextField fx:id="nom_p" promptText="Ex: Olive, Tomate..." styleClass="text-field" />
                                 </children>
                              </VBox>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="field-label" text="Type / Catégorie" />
                                    <TextField fx:id="type_p" promptText="Légume, Fruitier..." styleClass="text-field" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        
                        <HBox spacing="20.0">
                           <children>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="field-label" text="Début Plantation" />
                                    <DatePicker fx:id="date_debut_p" maxWidth="1.7976931348623157E308" styleClass="text-field" />
                                 </children>
                              </VBox>
                              <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="field-label" text="Fin Plantation" />
                                    <DatePicker fx:id="date_fin_p" maxWidth="1.7976931348623157E308" styleClass="text-field" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        
                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="field-label" text="Besoin en Eau" />
                              <TextField fx:id="besoin_eau_p" promptText="Faible, Moyen, Élevé..." styleClass="text-field" />
                           </children>
                        </VBox>
                        
                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="field-label" text="Description" />
                              <TextField fx:id="description_p" promptText="Détails supplémentaires..." styleClass="text-field" />
                           </children>
                        </VBox>
                        
                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#retourListe" styleClass="btn-secondary" text="Annuler" />
                              <Button fx:id="btnSave" mnemonicParsing="false" onAction="#save_plante" styleClass="btn-primary" text="Enregistrer la Plante" />
                           </children>
                           <padding>
                              <Insets top="10.0" />
                           </padding>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
