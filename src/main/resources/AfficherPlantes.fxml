<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" styleClass="root-pane" stylesheets="@ardhi.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AfficherPlantesController">
   <left>
      <VBox prefWidth="270.0" spacing="16" styleClass="sidebar" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="28.0" left="22.0" right="22.0" top="28.0" />
         </padding>
         <children>
            <Label styleClass="sidebar-title" text="Ardhi" />
            <Label text="Gestion des Plantes" styleClass="sidebar-section-title"/>
            <VBox spacing="10" styleClass="sidebar-panel">
                <Label text="Raccourcis" styleClass="sidebar-panel-title"/>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#retourAccueil" styleClass="sidebar-nav-button" text="Tableau de Bord" />
            </VBox>
         </children>
      </VBox>
   </left>
   <center>
      <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="content-scroll">
         <content>
            <VBox spacing="25.0" styleClass="content-box">
               <padding>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>
               <children>
                  <VBox spacing="12" styleClass="admin-header-card">
                     <children>
                        <Label styleClass="page-title" text="Liste des Plantes" />
                        <Label styleClass="auth-subtitle" text="Consultez et gérez le catalogue botanique de l'exploitation." />
                        <HBox spacing="10">
                           <children>
                              <Label text="Catalogue" styleClass="admin-chip"/>
                              <Label text="Botanique" styleClass="admin-chip"/>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  
                  <HBox alignment="CENTER_LEFT" spacing="20.0">
                     <children>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#allerVersAjout" styleClass="btn-primary" text="+ Ajouter une Plante" />
                     </children>
                  </HBox>
                  
                  <VBox styleClass="card, table-card" VBox.vgrow="ALWAYS">
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                     <children>
                        <TableView fx:id="planteTable" prefHeight="470" styleClass="table-compact" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colNom" prefWidth="150.0" text="Nom" />
                            <TableColumn fx:id="colType" prefWidth="150.0" text="Type" />
                              <TableColumn fx:id="colDebut" prefWidth="140.0" text="Début Plantation" />
                              <TableColumn fx:id="colFin" prefWidth="140.0" text="Fin Plantation" />
                              <TableColumn fx:id="colEau" prefWidth="130.0" text="Besoin Eau" />
                              <TableColumn fx:id="colDesc" prefWidth="210.0" text="Description" />
                              <TableColumn fx:id="colActions" prefWidth="210.0" text="Actions" />
                          </columns>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
