<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.SignInController" styleClass="auth-shell">
    <left>
        <VBox prefWidth="390" spacing="18" styleClass="auth-hero">
            <padding>
                <Insets top="46" right="34" bottom="46" left="34"/>
            </padding>
            <Label text="Ardhi" styleClass="brand-title"/>
            <Label text="Une experience plus professionnelle pour vos utilisateurs."
                   wrapText="true" styleClass="hero-title"/>
            <Label text="Connectez-vous, accedez a votre espace personnel et gardez une entree moderne vers les modules de la plateforme."
                   wrapText="true" styleClass="hero-text"/>
            <Label text="Connexion modernisee" styleClass="feature-pill"/>
            <VBox spacing="12">
                <Label text="Accueil dedie apres authentification" styleClass="feature-item"/>
                <Label text="Recuperation de mot de passe integree" styleClass="feature-item"/>
                <Label text="Validation email plus stricte et plus propre" styleClass="feature-item"/>
            </VBox>
        </VBox>
    </left>
    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="content-scroll">
            <content>
                <StackPane styleClass="auth-center">
                    <VBox maxWidth="470" spacing="16" styleClass="auth-card">
                        <padding>
                            <Insets top="36" right="36" bottom="36" left="36"/>
                        </padding>
                        <Label text="Connexion" styleClass="auth-title"/>
                        <Label text="Accedez a votre compte Ardhi et reprenez votre travail rapidement."
                               wrapText="true" styleClass="auth-subtitle"/>

                        <VBox spacing="8">
                            <Label text="Email" styleClass="field-label"/>
                            <TextField fx:id="emailField" promptText="nom@domaine.tn"/>
                        </VBox>

                        <VBox spacing="8">
                            <Label text="Mot de passe" styleClass="field-label"/>
                            <PasswordField fx:id="passwordField" promptText="Minimum 6 caracteres"/>
                        </VBox>

                        <Label fx:id="feedbackLabel" styleClass="error-label" wrapText="true"/>

                        <HBox alignment="CENTER_LEFT">
                            <Region HBox.hgrow="ALWAYS"/>
                            <Hyperlink text="Mot de passe oublie ?" onAction="#goToForgotPassword"/>
                        </HBox>

                        <Button text="Se connecter" onAction="#handleSignIn" styleClass="btn-primary" maxWidth="1.7976931348623157E308"/>

                        <HBox alignment="CENTER" spacing="10">
                            <Region styleClass="separator-line" HBox.hgrow="ALWAYS"/>
                            <Label text="ou" styleClass="separator-label"/>
                            <Region styleClass="separator-line" HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <Button text="Continuer avec Google" onAction="#handleGoogleSignIn" styleClass="btn-google" maxWidth="1.7976931348623157E308"/>

                        <Button text="Continuer avec Face ID" onAction="#handleFaceIdLogin" styleClass="btn-faceid" maxWidth="1.7976931348623157E308"/>
                        <Label text="Pour Face ID, saisissez d'abord l'email du compte." styleClass="helper-label" wrapText="true"/>

                        <HBox alignment="CENTER" spacing="6">
                            <Label text="Vous n'avez pas encore de compte ?" styleClass="muted-label"/>
                            <Hyperlink text="Creer un compte" onAction="#goToSignUp"/>
                        </HBox>
                    </VBox>
                </StackPane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
