<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="450.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 20;" stylesheets="@ardhi.css" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.FormulaireSourceController">
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
   <children>
      <!-- Header Section -->
      <VBox spacing="8.0">
         <children>
            <Label text="💰 Source de Financement" styleClass="auth-title">
               <font><Font name="System Bold" size="22.0" /></font>
            </Label>
            <Label text="Remplissez les informations pour enregistrer un nouveau capital." styleClass="auth-subtitle" wrapText="true" />
         </children>
      </VBox>

      <Separator opacity="0.4" />

      <!-- Form Fields -->
      <VBox spacing="18.0">
         <children>
            <VBox spacing="8.0">
               <children>
                  <Label text="Nom de la source" styleClass="field-label" />
                  <TextField fx:id="nomField" prefHeight="45.0" promptText="Ex: Banque Centrale, Fonds Propres..." styleClass="text-field" />
               </children>
            </VBox>

            <VBox spacing="8.0">
               <children>
                  <Label text="Type de financement" styleClass="field-label" />
                  <ComboBox fx:id="typeCombo" maxWidth="1.7976931348623157E308" prefHeight="45.0" styleClass="combo-box" />
               </children>
            </VBox>

            <VBox spacing="8.0">
               <children>
                  <Label text="Montant (DT)" styleClass="field-label" />
                  <TextField fx:id="montantField" prefHeight="45.0" promptText="0.00" styleClass="text-field" />
               </children>
            </VBox>
         </children>
      </VBox>

      <Region VBox.vgrow="ALWAYS" />

      <!-- Action Buttons -->
      <HBox spacing="15.0" alignment="CENTER_RIGHT">
         <children>
            <Button onAction="#annulerAction" prefHeight="45.0" prefWidth="120.0" styleClass="btn-secondary" text="Annuler" />
            <Button onAction="#enregistrerAction" prefHeight="45.0" prefWidth="150.0" styleClass="btn-primary" text="Enregistrer" />
         </children>
      </HBox>
   </children>
</VBox>
