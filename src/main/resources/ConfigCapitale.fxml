<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="750.0" prefWidth="1100.0" style="-fx-background-color: #F3F4F6;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ConfigCapitaleController">
   <children>
      <VBox spacing="25.0" AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="25.0">
         <children>
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Button onAction="#retourDashboard" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 10 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);" text="⬅️ Dashboard Finance" />
                  <VBox>
                     <children>
                        <Label text="Configuration du Capital" textFill="#063D2F">
                           <font><Font name="System Bold" size="26.0" /></font>
                        </Label>
                        <Label text="Gerez la structure de votre financement de maniere visuelle" textFill="#6B7280" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <HBox spacing="25.0" VBox.vgrow="ALWAYS">
               <children>
                  <!-- Left Side -->
                  <VBox spacing="25.0" HBox.hgrow="ALWAYS">
                     <children>
                        <!-- Card: General Info -->
                        <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 8);">
                           <children>
                              <Label text="1. Informations Generales" textFill="#085041"><font><Font name="System Bold" size="16.0" /></font></Label>
                              <GridPane hgap="20.0" vgap="15.0">
                                <columnConstraints>
                                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                </columnConstraints>
                                 <children>
                                    <VBox spacing="5.0">
                                       <children>
                                          <Label text="Devise de reference" textFill="#4B5563" />
                                          <ComboBox fx:id="deviseCombo" prefHeight="40.0" prefWidth="400.0" style="-fx-background-radius: 10;" />
                                       </children>
                                    </VBox>
                                    <VBox spacing="5.0" GridPane.columnIndex="1">
                                       <children>
                                          <Label text="Seuil d'alerte financier (DT)" textFill="#4B5563" />
                                          <TextField fx:id="seuilField" prefHeight="40.0" style="-fx-background-radius: 10;" text="1000" />
                                       </children>
                                    </VBox>
                                 </children>
                                 <rowConstraints>
                                    <RowConstraints />
                                    <RowConstraints minHeight="10.0" prefHeight="30.0" />
                                 </rowConstraints>
                              </GridPane>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Description / Objectif du capital" textFill="#4B5563" />
                                    <TextArea fx:id="descField" prefHeight="80.0" promptText="Expliquez ici l'origine ou l'usage prevu de ce capital..." style="-fx-background-radius: 10;" />
                                 </children>
                              </VBox>
                           </children>
                        </VBox>

                        <!-- Visual Source Cards Section -->
                        <VBox spacing="15.0" VBox.vgrow="ALWAYS">
                           <children>
                              <HBox alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="2. Sources de Financement" textFill="#085041"><font><Font name="System Bold" size="16.0" /></font></Label>
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button onAction="#ouvrirAjoutSource" style="-fx-background-color: #085041; -fx-text-fill: white; -fx-background-radius: 10;" text="+ Nouvelle Source" />
                                 </children>
                              </HBox>
                              
                              <!-- ScrollPane for Cards -->
                              <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                                 <content>
                                    <FlowPane fx:id="sourcesFlowPane" hgap="20.0" vgap="20.0">
                                       <padding><Insets bottom="10.0" left="5.0" right="10.0" top="10.0" /></padding>
                                    </FlowPane>
                                 </content>
                              </ScrollPane>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <!-- Right Side -->
                  <VBox prefWidth="380.0" spacing="25.0">
                     <children>
                        <VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #063D2F; -fx-background-radius: 20; -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 10);">
                           <children>
                              <Label text="CAPITAL TOTAL" textFill="#5DCAA5"><font><Font name="System Bold" size="14.0" /></font></Label>
                              <Label fx:id="totalCapitalLabel" text="0.00 DT" textFill="WHITE"><font><Font name="System Bold" size="38.0" /></font></Label>
                              <Separator opacity="0.1" prefWidth="200.0" />
                              <VBox alignment="CENTER" spacing="5.0">
                                 <children>
                                    <Label fx:id="riskLabel" text="Situation Stable" textFill="#5DCAA5"><font><Font name="System Bold" size="13.0" /></font></Label>
                                    <ProgressBar fx:id="riskBar" prefWidth="200.0" progress="0.2" style="-fx-accent: #5DCAA5;" />
                                 </children>
                              </VBox>
                           </children>
                        </VBox>

                        <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 8);">
                           <children>
                              <Label text="Repartition" textFill="#085041"><font><Font name="System Bold" size="16.0" /></font></Label>
                              <PieChart fx:id="repartitionChart" VBox.vgrow="ALWAYS" minHeight="380.0" prefHeight="380.0" />
                           </children>
                        </VBox>
                        
                        <Button onAction="#enregistrerConfigAction" prefHeight="50.0" prefWidth="400.0" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-weight: bold;" text="VALIDER LA CONFIGURATION" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
