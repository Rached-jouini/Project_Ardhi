<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1150.0" styleClass="root-pane" stylesheets="@ardhi.css" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ConfigCapitaleController">
    
    <!-- Sidebar Gauche -->
    <left>
        <VBox prefWidth="270" spacing="16" styleClass="sidebar" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="28" right="22" bottom="28" left="22"/>
            </padding>
            <Label text="Ardhi" styleClass="sidebar-title"/>
            <Label text="Gestion du Capital" styleClass="sidebar-section-title" wrapText="true"/>
            
            <VBox spacing="10" styleClass="sidebar-panel">
                <Label text="Raccourcis" styleClass="sidebar-panel-title"/>
                <Button text="Tableau de Bord" onAction="#retourDashboard" styleClass="sidebar-nav-button" maxWidth="1.7976931348623157E308"/>
            </VBox>
            
            <Region VBox.vgrow="ALWAYS"/>
            <Label text="Module Financier" styleClass="feature-pill"/>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <content>
                <VBox spacing="24" styleClass="content-box">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <!-- Header Card -->
                    <VBox spacing="12" styleClass="admin-header-card">
                        <Label text="Configuration du Capital" styleClass="page-title" textFill="WHITE"/>
                        <Label text="Gerez la structure de votre financement, definissez vos seuils d'alerte et suivez la repartition de vos fonds." 
                               wrapText="true" styleClass="auth-subtitle" textFill="WHITE"/>
                        <HBox spacing="10">
                            <Label text="Fonds Propres" styleClass="admin-chip"/>
                            <Label text="Emprunts" styleClass="admin-chip"/>
                            <Label text="Analyse de Risque" styleClass="admin-chip"/>
                        </HBox>
                    </VBox>

                    <HBox spacing="24">
                        <!-- Left Section -->
                        <VBox spacing="20" HBox.hgrow="ALWAYS">
                            <!-- Card: Parametres de Reference -->
                            <VBox spacing="20" styleClass="card">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="1. Parametres de Reference" styleClass="section-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label text="⚙️ Configuration" styleClass="muted-label"/>
                                </HBox>
                                
                                <GridPane hgap="30" vgap="20">
                                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                        <Label text="🌍 Devise de reference" styleClass="field-label"/>
                                        <ComboBox fx:id="deviseCombo" maxWidth="1.7976931348623157E308" prefHeight="45" styleClass="combo-box"/>
                                        <Label text="La devise appliquee aux rapports" styleClass="muted-label" style="-fx-font-size: 11;"/>
                                    </VBox>
                                    
                                    <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                        <Label text="🔔 Seuil d'alerte financier (DT)" styleClass="field-label"/>
                                        <TextField fx:id="seuilField" prefHeight="45" styleClass="text-field" promptText="Ex: 1000"/>
                                        <Label text="Alerte visuelle sous ce montant" styleClass="muted-label" style="-fx-font-size: 11;"/>
                                    </VBox>
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="10.0" prefHeight="70.0" />
                                    </rowConstraints>
                                </GridPane>

                                <Separator opacity="0.4"/>

                                <VBox spacing="8">
                                    <Label text="📝 Description / Objectif du capital" styleClass="field-label"/>
                                    <TextArea fx:id="descField" prefHeight="100" promptText="Decrivez ici l'origine des fonds ou l'objectif strategique..." styleClass="text-area" wrapText="true"/>
                                </VBox>
                            </VBox>

                            <!-- Sources Section -->
                            <VBox spacing="15">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="2. Sources de Financement" styleClass="section-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="+ Nouvelle Source" onAction="#ouvrirAjoutSource" styleClass="btn-primary"/>
                                </HBox>
                                <FlowPane fx:id="sourcesFlowPane" hgap="16" vgap="16"/>
                            </VBox>
                        </VBox>

                        <!-- Right Section: Stats -->
                        <VBox spacing="20" prefWidth="380">
                            <VBox spacing="20" styleClass="hero-card">
                                <Label text="CAPITAL TOTAL" styleClass="stat-title" textFill="#5dcaa5"/>
                                <Label fx:id="totalCapitalLabel" text="0.00 DT" styleClass="hero-heading"/>
                                <Separator opacity="0.2"/>
                                <VBox spacing="8">
                                    <Label fx:id="riskLabel" text="Situation stable" styleClass="hero-copy"/>
                                    <ProgressBar fx:id="riskBar" maxWidth="1.7976931348623157E308" progress="0.2"/>
                                </VBox>
                            </VBox>

                            <VBox spacing="15" styleClass="card">
                                <Label text="Repartition" styleClass="section-title"/>
                                <PieChart fx:id="repartitionChart" prefHeight="300"/>
                            </VBox>
                            
                            <Button text="VALIDER LA CONFIGURATION" onAction="#enregistrerConfigAction" maxWidth="1.7976931348623157E308" styleClass="btn-primary" prefHeight="50"/>
                        </VBox>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
