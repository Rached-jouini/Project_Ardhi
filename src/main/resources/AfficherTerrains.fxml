<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AfficherTerrainsController">
   <left>
      <VBox prefWidth="240.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="sidebar-title" text="Ardhi Admin" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-button, sidebar-button-active" text="Gestion Terrains" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#allerVersPlantes" styleClass="sidebar-button" text="Gestion Plantes" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#passerAuClient" style="-fx-background-color: transparent; -fx-text-fill: #10B981; -fx-padding: 30 0 0 0;" text="➡ Passer au Client" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#retourAccueil" style="-fx-background-color: transparent; -fx-text-fill: #6B7280; -fx-padding: 10 0 0 0;" text="🏠 Retour Accueil" />
         </children>
      </VBox>
   </left>
   <center>
      <VBox spacing="25.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="title-page" text="Liste des Terrains" />
                        <Label styleClass="label-standard" text="Consultez, modifiez ou supprimez les parcelles enregistrées." />
                     </children>
                  </VBox>
                  <Button mnemonicParsing="false" onAction="#allerVersAjout" styleClass="button-primary" text="+ Ajouter un Terrain" />
               </children>
            </HBox>
            
            <VBox styleClass="card" VBox.vgrow="ALWAYS">
               <children>
                  <TableView fx:id="terrainTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colRegion" prefWidth="150.0" text="Région" />
                      <TableColumn fx:id="colSuperficie" prefWidth="120.0" text="Superficie (m²)" />
                        <TableColumn fx:id="colType" prefWidth="150.0" text="Type de Sol" />
                        <TableColumn fx:id="colStatut" prefWidth="120.0" text="Statut" />
                        <TableColumn fx:id="colPrix" prefWidth="120.0" text="Prix (TND/m)" />
                        <TableColumn fx:id="colActions" prefWidth="200.0" text="Actions" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
         </children>
      </VBox>
   </center>
</BorderPane>
