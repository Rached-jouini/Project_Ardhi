<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" styleClass="root-pane" stylesheets="@ardhi.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AfficherTerrainsController">
   <left>
      <VBox prefWidth="270.0" spacing="16" styleClass="sidebar" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="28.0" left="22.0" right="22.0" top="28.0" />
         </padding>
         <children>
            <Label styleClass="sidebar-title" text="Ardhi" />
            <Label text="Gestion des Terrains" styleClass="sidebar-section-title"/>
            <VBox spacing="10" styleClass="sidebar-panel">
                <Label text="Raccourcis" styleClass="sidebar-panel-title"/>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#retourAccueil" styleClass="sidebar-nav-button" text="Tableau de Bord" />
            </VBox>
         </children>
      </VBox>
   </left>
   <center>
      <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="content-scroll">
         <content>
            <VBox spacing="25.0" styleClass="content-box">
               <padding>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>
               <children>
                  <VBox spacing="12" styleClass="admin-header-card">
                     <children>
                        <Label styleClass="page-title" text="Liste des Terrains" />
                        <Label styleClass="auth-subtitle" text="Consultez, modifiez ou supprimez les parcelles enregistrées." />
                        <HBox spacing="10">
                           <children>
                              <Label text="Gestion foncière" styleClass="admin-chip"/>
                              <Label text="Validation" styleClass="admin-chip"/>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  
                  <HBox alignment="CENTER_LEFT" spacing="20.0">
                     <children>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#allerVersAjout" styleClass="btn-primary" text="+ Ajouter un Terrain" />
                     </children>
                  </HBox>
                  
                  <VBox styleClass="card, table-card" VBox.vgrow="ALWAYS">
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                     <children>
                        <TableView fx:id="terrainTable" prefHeight="470" styleClass="table-compact" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colRegion" prefWidth="180.0" text="Région" />
                            <TableColumn fx:id="colSuperficie" prefWidth="130.0" text="Superficie (m²)" />
                              <TableColumn fx:id="colType" prefWidth="160.0" text="Type de Sol" />
                              <TableColumn fx:id="colStatut" prefWidth="130.0" text="Statut" />
                              <TableColumn fx:id="colPrix" prefWidth="130.0" text="Prix (TND/m)" />
                              <TableColumn fx:id="colActions" prefWidth="210.0" text="Actions" />
                          </columns>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
