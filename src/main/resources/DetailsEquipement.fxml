<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="800.0" style="-fx-background-color: white; -fx-background-radius: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 20, 0, 0, 10);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.DetailsEquipementController">
   <children>
      <HBox spacing="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            
            <!-- Left Side: Large Image -->
            <StackPane prefWidth="400.0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 30 0 0 30;">
               <children>
                  <ImageView fx:id="mainImageView" fitHeight="350.0" fitWidth="350.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../images/default_equip.png" />
                     </image>
                  </ImageView>
                  <Label fx:id="statusBadge" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 20; -fx-font-weight: bold;" text="DISPONIBLE" StackPane.alignment="TOP_LEFT">
                     <StackPane.margin><Insets left="20.0" top="20.0" /></StackPane.margin>
                  </Label>
               </children>
            </StackPane>
            
            <!-- Right Side: Details & Actions -->
            <VBox prefWidth="400.0" spacing="20.0" style="-fx-padding: 40;">
               <children>
                  <HBox alignment="CENTER_RIGHT">
                     <children>
                        <Button onAction="#close" style="-fx-background-color: #F1F5F9; -fx-background-radius: 50; -fx-padding: 10;" text="✕" textFill="#64748B" />
                     </children>
                  </HBox>
                  
                  <VBox spacing="5.0">
                     <children>
                        <Label fx:id="typeLabel" text="TRACTEUR" textFill="#64748B">
                           <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <Label fx:id="nameLabel" text="John Deere 5075E" textFill="#1E293B">
                           <font><Font name="System Bold" size="26.0" /></font>
                        </Label>
                     </children>
                  </VBox>
                  
                  <Separator opacity="0.3" />
                  
                  <VBox spacing="10.0">
                     <children>
                        <Label text="Description" textFill="#1E293B">
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <Label fx:id="descLabel" lineSpacing="5.0" text="Ce tracteur utility John Deere est idéal pour les travaux de ferme quotidiens. Puissant, fiable et économe en carburant." textFill="#64748B" wrapText="true" />
                     </children>
                  </VBox>
                  
                  <Separator opacity="0.3" />
                  
                  <!-- Analyse de Rentabilité -->
                  <VBox spacing="10.0" style="-fx-background-color: #F8FAFC; -fx-padding: 15; -fx-background-radius: 15;">
                     <children>
                        <Label text="Analyse de Rentabilité" textFill="#1E293B">
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <HBox spacing="20.0">
                           <children>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Revenu Total" textFill="#64748B" style="-fx-font-size: 10;" />
                                    <Label fx:id="totalRevenueLabel" text="0.00 DT" textFill="#10B981" style="-fx-font-weight: bold; -fx-font-size: 14;" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Maintenance" textFill="#64748B" style="-fx-font-size: 10;" />
                                    <Label fx:id="maintenanceCostLabel" text="0.00 DT" textFill="#EF4444" style="-fx-font-weight: bold; -fx-font-size: 14;" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Net" textFill="#64748B" style="-fx-font-size: 10;" />
                                    <Label fx:id="netProfitLabel" text="0.00 DT" textFill="#063D2F" style="-fx-font-weight: bold; -fx-font-size: 14;" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  
                  <Region VBox.vgrow="ALWAYS" />
                  
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <VBox>
                           <children>
                              <Label text="Prix / jour" textFill="#64748B" style="-fx-font-size: 11;" />
                              <Label fx:id="priceLabel" text="150.00 DT" textFill="#063D2F">
                                 <font><Font name="System Bold" size="22.0" /></font>
                              </Label>
                           </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #F8FAFC; -fx-padding: 5 15; -fx-background-radius: 12;">
                           <children>
                              <Button onAction="#decrementQuantity" style="-fx-background-color: transparent; -fx-font-size: 18; -fx-font-weight: bold; -fx-cursor: hand;" text="-" />
                              <Label fx:id="quantityLabel" text="1">
                                 <font><Font name="System Bold" size="16.0" /></font>
                              </Label>
                              <Button onAction="#incrementQuantity" style="-fx-background-color: transparent; -fx-font-size: 18; -fx-font-weight: bold; -fx-cursor: hand;" text="+" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>
                  
                  <Button fx:id="addToCartBtn" onAction="#addToCart" prefHeight="55.0" prefWidth="320.0" style="-fx-background-color: #063D2F; -fx-text-fill: white; -fx-background-radius: 15; -fx-font-size: 16; -fx-font-weight: bold; -fx-cursor: hand;" text="AJOUTER AU PANIER" />
               </children>
            </VBox>
            
         </children>
      </HBox>
   </children>
</AnchorPane>
