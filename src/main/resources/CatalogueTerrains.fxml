<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" styleClass="root-pane" stylesheets="@ardhi.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.CatalogueTerrainsController">
   <left>
      <VBox prefWidth="270.0" spacing="16" styleClass="sidebar" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="28.0" left="22.0" right="22.0" top="28.0" />
         </padding>
         <children>
            <Label styleClass="sidebar-title" text="Ardhi" />
            <Label text="Catalogue" styleClass="sidebar-section-title"/>
            <VBox spacing="10" styleClass="sidebar-panel">
                <Label text="Raccourcis" styleClass="sidebar-panel-title"/>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#retourAccueil" styleClass="sidebar-nav-button" text="🏠 Retour Accueil" />
            </VBox>
         </children>
      </VBox>
   </left>
   <center>
      <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="content-scroll">
         <content>
            <VBox spacing="25.0" styleClass="content-box">
               <padding>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>
               <children>
                  <VBox spacing="12" styleClass="admin-header-card">
                     <children>
                        <Label styleClass="page-title" text="Terrains Disponibles" />
                        <Label styleClass="auth-subtitle" text="Choisissez une parcelle pour lancer votre exploitation agricole." />
                        <HBox spacing="10">
                           <children>
                              <Label text="Location" styleClass="admin-chip"/>
                              <Label text="Agriculture" styleClass="admin-chip"/>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  
                  <ScrollPane fitToWidth="true" styleClass="content-scroll" VBox.vgrow="ALWAYS">
                     <content>
                        <FlowPane fx:id="terrainContainer" hgap="25.0" vgap="25.0" styleClass="content-box">
                           <padding>
                              <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                           </padding>
                        </FlowPane>
                     </content>
                  </ScrollPane>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
