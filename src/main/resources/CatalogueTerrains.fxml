<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.CatalogueTerrainsController">
   <left>
      <VBox prefWidth="240.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="sidebar-title" text="Ardhi Client" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-button, sidebar-button-active" text="Catalogue Terrains" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#passerALAdmin" style="-fx-background-color: transparent; -fx-text-fill: #F87171; -fx-padding: 30 0 0 0;" text="⬅ Administration" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#retourAccueil" style="-fx-background-color: transparent; -fx-text-fill: #6B7280; -fx-padding: 10 0 0 0;" text="🏠 Retour Accueil" />
         </children>
      </VBox>
   </left>
   <center>
      <VBox spacing="25.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="title-page" text="Terrains Disponibles" />
                  <Label styleClass="label-standard" text="Choisissez une parcelle pour lancer votre exploitation agricole." />
               </children>
            </VBox>
            
            <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
               <content>
                  <FlowPane fx:id="terrainContainer" hgap="25.0" vgap="25.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </FlowPane>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </center>
</BorderPane>
